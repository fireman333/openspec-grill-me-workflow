# OpenSpec config.yaml — generated by /spec init
# Curator-mode rules + project defaults. Manually maintain after init.
# Reference: https://github.com/Fission-AI/OpenSpec

# Inject project.md content into every artifact-generation prompt
# so OpenSpec AI sees Purpose / Stack / Constraints automatically.
context:
  project_md: openspec/project.md

# Hard rules enforced on every /opsx:* invocation.
# These mitigate known LLM failure modes (GitHub issues #834, #869):
# - LLMs sometimes skip propose -> apply order
# - LLMs sometimes implement code without first writing the spec
rules:
  # === Curator philosophy ===
  - id: no-auto-commit
    rule: "Never run `git commit` automatically. All commits go through the user via the auto-git skill or explicit confirmation."
  - id: ask-on-non-trivial
    rule: "For any non-trivial decision (architecture, library choice, naming convention, scope cut), use AskUserQuestion before writing it into a proposal/spec."
  - id: phi-zero-tolerance
    rule: "Never write real patient identifiers (name / ID / chart number / DOB / address / phone) into any openspec/ file. If detected in user input, halt and route to /phi-deid."

  # === Workflow integrity ===
  - id: no-skip-propose
    rule: "Do not implement code changes without first running /opsx:propose for the change. The propose -> apply -> verify -> archive sequence is mandatory for any change touching openspec/specs/."
  - id: no-archive-without-verify
    rule: "Do not archive a change before /opsx:verify reports green on completeness/correctness/coherence."

  # === Project-specific retreats ===
  # If these files appear in the project, OpenSpec should warn that another
  # workflow owns the directory. Set in spec-driven SessionStart hook too.
  - id: retreat-research-plan
    rule: "If project contains research_plan.json at root, halt OpenSpec workflow and suggest /research-plan instead. This is a statistical project, not a code project."
  - id: retreat-meta-analysis
    rule: "If project contains 01_protocol/ + 09_qa/ at root, halt and suggest /ma-end-to-end. This is a meta-analysis project."

# Project defaults — adjust per project
defaults:
  # Spec format conventions
  requirement_keyword: SHALL  # RFC 2119 default. Allowed: MUST, SHALL, SHOULD, MAY
  scenario_format: bdd        # WHEN/THEN style
  capability_slug_case: kebab # kebab-case for capability folder names

  # Change naming
  change_slug_pattern: "<verb>-<object>"  # e.g. add-greeting, remove-legacy-auth
